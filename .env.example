# Required: get one from https://console.cloud.google.com -> APIs & Services -> Credentials.
# Enable the "Routes API" for your project.
GOOGLE_API_KEY=your_api_key_here

# Optional: seed a default route on first start.
DEFAULT_ORIGIN=
DEFAULT_DESTINATION=

# Morning sampling window (home -> office).
TIME_WINDOW_START=07:00
TIME_WINDOW_END=09:00
# Evening sampling window (office -> home).
EVENING_TIME_WINDOW_START=16:00
EVENING_TIME_WINDOW_END=18:30
INTERVAL_MINUTES=15
DEFAULT_WEEKDAYS=Mon,Tue,Wed,Thu,Fri

# Daily recompute time (container local TZ).
SCHEDULER_HOUR=4
SCHEDULER_MINUTE=0

# Concurrency for the daily sample run.
CONCURRENT_REQUESTS=10

# Optional. If set, all /api/* endpoints require header  X-API-Key: <value>
API_KEY=

# Timezone (e.g. Europe/Berlin, America/Los_Angeles).
TZ=Europe/Berlin
