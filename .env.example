# Required: get one from https://console.cloud.google.com -> APIs & Services -> Credentials.
# Enable the "Routes API" for your project.
GOOGLE_API_KEY=your_api_key_here

# Optional: seed a default route on first start.
DEFAULT_ORIGIN=
DEFAULT_DESTINATION=

# Morning sampling window (home -> office).
TIME_WINDOW_START=07:00
TIME_WINDOW_END=09:00
# Evening sampling window (office -> home).
EVENING_TIME_WINDOW_START=16:00
EVENING_TIME_WINDOW_END=18:30
INTERVAL_MINUTES=15
DEFAULT_WEEKDAYS=Mon,Tue,Wed,Thu,Fri

# Daily recompute time (container local TZ).
SCHEDULER_HOUR=4
SCHEDULER_MINUTE=0

# Concurrency for the daily sample run.
CONCURRENT_REQUESTS=10

# --- Multi-user accounts -----------------------------------------------------
# The app is multi-user (invite-only). On first start an admin account is seeded
# from these; the admin then creates other users in the UI (Users tab). CHANGE
# the password, and set it BEFORE first start so it never uses the default.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
# Login session lifetime, and whether the cookie is marked Secure. Keep Secure
# off for plain-http LAN access (e.g. http://nas:8088); turn on behind HTTPS.
SESSION_TTL_DAYS=30
COOKIE_SECURE=false
# Per-user daily cap on Google Routes API calls (shared key, you pay). Over the
# cap, that user's live lookups fall back to the stored snapshot. 0 = unlimited.
USER_DAILY_API_BUDGET=250
# NOTE: the old global API_KEY is retired. Programmatic access now uses each
# user's personal API token (Account tab) sent as the  X-API-Key  header.

# Optional proactive push. Set either to enable a periodic in-window check that
# notifies you when live conditions cross PUSH_MIN_SEVERITY. This spends extra
# Routes API calls ONLY while a commute window is open — see docs/OPERATIONS.md.
# NTFY_TOPIC_URL=https://ntfy.sh/your-private-topic
# WEBHOOK_URL=https://example.com/hooks/commute
PUSH_MIN_SEVERITY=alert
PUSH_CHECK_MINUTES=15

# Timezone (e.g. Europe/Berlin, America/Los_Angeles).
TZ=Europe/Berlin

# Bonn real-time street-traffic open data (free, CC-BY). When enabled, the app
# shows a live local-traffic panel and folds Bonn congestion into incident
# alerts. Segments are auto-matched to your route geometry at config/recompute
# time. Only relevant for commutes through Bonn; set false to disable entirely.
# Attribution required: "Datenquelle: Bundesstadt Bonn, Amt 66".
BONN_TRAFFIC_ENABLED=true
BONN_TRAFFIC_URL=https://stadtplan.bonn.de/geojson?Thema=19584
BONN_CACHE_SECONDS=300
BONN_MATCH_RADIUS_M=40
BONN_MATCH_MIN_FRACTION=0.5
